# ===== WASTEWISE APPLICATION CONFIGURATION =====
# Product: WasteWise - Premium eco-app for waste classification, carbon tracking, and green rewards
# Version: 1.0.0
# Team: WasteWise Team
# Homepage: https://wastewise.eco
# ===================================================

# Database Configuration
DATABASE_NAME=waste_data.db

# Server Configuration
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_EXTENSIONS=jpg,jpeg,png,gif,webp

# Security
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
